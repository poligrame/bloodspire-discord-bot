# ── Discord ──────────────────────────────────────────────────────────────
# Token du bot : Discord Developer Portal > ton appli > Bot > Reset Token
DISCORD_TOKEN=

# ID du salon ou le bot doit poster le message "Reclamer le titre"
# (clic droit sur le salon dans Discord > Copier l'identifiant, mode
# developpeur doit etre active : Parametres > Avance > Mode developpeur)
CHANNEL_ID=

# ── Serveur Minecraft (RCON) ─────────────────────────────────────────────
# IP/domaine du serveur Minecraft (PAS le port de jeu, celui du RCON)
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=

# ── Titre ────────────────────────────────────────────────────────────────
# Doit correspondre exactement a l'id du titre cree avec /titre create ou /titre add
TITLE_ID=discord

# ── Systeme de tickets ───────────────────────────────────────────────────
# Salon ou le bot poste le panneau "Ouvrir un ticket" (boutons Candidature /
# Bug / Joueur). Clic droit sur le salon > Copier l'identifiant.
PANEL_CHANNEL_ID=1520818830656671925

# (Optionnel) Categorie sous laquelle creer les salons de ticket. Vide = racine.
TICKET_CATEGORY_ID=

# Salon "demande-de-tickets" : le bot y poste les demandes d'ouverture de ticket
# humain, qu'un admin doit Accepter/Refuser. Vide = utilise PANEL_CHANNEL_ID.
REQUEST_CHANNEL_ID=

# (Optionnel) Salon de logs admin : le bot y journalise UNIQUEMENT l'ouverture
# des tickets humains. Mets un salon visible du staff uniquement.
LOG_CHANNEL_ID=

# IDs (roles OU membres) qui ont acces aux tickets escalades au staff et qui
# peuvent les fermer. Separes par des virgules.
TICKET_STAFF_IDS=1520785939805372436,1520786295901651026,1520788267778179123

# ── IA (AWS Bedrock — Claude Sonnet 4.5) ─────────────────────────────────
# Region AWS ou Bedrock est active.
BEDROCK_REGION=us-east-1
# Profil d'inference Bedrock pour Claude Sonnet 4.5.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# MODE SIMPLE (recommande) : une seule cle API Bedrock (jeton Bearer).
AWS_BEARER_TOKEN_BEDROCK=
# MODE CLASSIQUE IAM (laisser le Bearer vide) : cle d'acces + secret.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# (Optionnel) jeton de session pour des credentials temporaires.
AWS_SESSION_TOKEN=
